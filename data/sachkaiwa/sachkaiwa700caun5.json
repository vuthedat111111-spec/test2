        "dialogues": [
          { "speaker": "A", "ja": "どうもありがとうございます", "vi": "Cảm ơn chị." },
          { "speaker": "B", "ja": "いいえ、どういたしまして。", "vi": "Không, không có gì." }
        ]
      },
