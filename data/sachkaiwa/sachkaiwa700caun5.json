        ]
      },
      {
        "context": "Tình huống 3",
        "dialogues": [
          { "speaker": "A", "ja": "えみさん、じゃーね。", "vi": "Emi, hẹn gặp lại cậu sau." },
          { "speaker": "B", "ja": "うん。また明日。", "vi": "Ừ, Mai gặp lại nhé." }
        ]
      },
      {
        "context": "Tình huống 4",
        "dialogues": [
          { "speaker": "A", "ja": "お先に失礼します。", "vi": "Tôi xin phép về trước." },
          { "speaker": "B", "ja": "おつかれさまー。", "vi": "Cảm ơn anh đã vất vả làm việc. (Hẹn gặp anh ngày mai)" }
